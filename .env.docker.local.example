# ===========================================
# Variables de entorno - DOCKER LOCAL (Desarrollo)
# ===========================================
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.docker.local.example .env.docker.local
#   2. Editar los valores según tu entorno local
#   3. NO commitear el archivo .env.docker.local (ya está en .gitignore)
# ===========================================

# ── PostgreSQL ──
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace_with_local_db_password
POSTGRES_DB=app_db
POSTGRES_PORT=5432

# ── JWT (Desarrollo - puedes dejar estos valores para local) ──
JWT_SECRET=tu_secreto_super_seguro_access_token_desarrollo_2026
JWT_REFRESH_SECRET=tu_secreto_super_seguro_refresh_token_desarrollo_2026

# ── GROQ AI (Chatbot) ──
# Pon tu API key real aquí
GROQ_API_KEY=replace_with_groq_api_key
