# ==========================================
# Frontend - Variables de entorno (DESARROLLO LOCAL)
# ==========================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.local.example .env.local
#   2. Ajusta URLs si cambias puertos
#   3. NO subas el archivo .env.local real al repositorio

# URL del sitio (cliente)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL del backend para SSR/proxy interno
BACKEND_URL=http://localhost:3001

# URL pública del API (cliente)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
