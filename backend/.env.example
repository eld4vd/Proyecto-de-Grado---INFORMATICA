# ==========================================
# Backend - Variables de entorno (DESARROLLO LOCAL)
# ==========================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Completa los valores segun tu entorno
#   3. NO subas el archivo .env real al repositorio

# Base de datos (local)
DATABASE_URL="postgresql://usuario:password@localhost:5432/tech?schema=public"

# Servidor
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT
# Genera secretos con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_access_token_secret
JWT_REFRESH_SECRET=replace_with_refresh_token_secret

# GROQ AI (opcional)
GROQ_API_KEY=replace_with_groq_api_key
