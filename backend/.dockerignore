# ===========================================
# BACKEND .dockerignore
# ===========================================

# Dependencias (se instalan dentro del contenedor)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (se genera dentro del contenedor)
dist
build

# Generated Prisma client (se genera con prisma generate)
src/generated

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.sublime-*

# OS
.DS_Store
Thumbs.db
nul

# Env files (se inyectan via docker-compose)
.env
.env.*

# Tests
coverage
__tests__
test

# Docs y agentes
docs
.agents
skills-lock.json

# TypeScript cache
*.tsbuildinfo

# Archivos innecesarios
README.md
test_commits.txt
