# ===========================================
# BACKEND - Dockerfile DESARROLLO LOCAL
# NestJS 11 + Prisma 7 con hot-reload
# ===========================================
FROM node:22-alpine

WORKDIR /app

# Instalar dependencias del sistema
RUN apk add --no-cache libc6-compat openssl

# Copiar archivos de dependencias
COPY package.json package-lock.json ./

# Instalar todas las dependencias (incluyendo dev)
RUN npm ci

# Copiar código fuente
COPY . .

# Habilitar polling para hot-reload en Docker (Windows/Mac)
ENV CHOKIDAR_USEPOLLING=true

EXPOSE 3001

# Generar Prisma Client y ejecutar en modo desarrollo
# prisma generate se ejecuta al iniciar porque los volúmenes
# montan el código fuente DESPUÉS del build de la imagen
CMD ["sh", "-c", "npx prisma generate && npm run start:dev"]
